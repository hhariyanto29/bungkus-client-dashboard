# Server Configuration
PORT=3001
NODE_ENV=development

# Database Configuration
DB_TYPE=postgres # or sqlite
DATABASE_URL=postgresql://user:password@host:5432/bungkus_db # Railway auto-provides this

# SQLite Configuration (if using sqlite for local dev)
SQLITE_PATH=./bungkus.db

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRES_IN=30d
QR_TOKEN_EXPIRES_IN=30d

# Security
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000 # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# QR Configuration
QR_BASE_URL=http://localhost:3000/access
QR_ENCRYPTION_KEY=your_encryption_key_change_this

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880 # 5MB

# Email Configuration (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@bungkus.com

# Third-party APIs
RAJAONGKIR_API_KEY=your_rajaongkir_key
MIDTRANS_SERVER_KEY=your_midtrans_server_key
MIDTRANS_CLIENT_KEY=your_midtrans_client_key
JNE_API_KEY=your_jne_key
TIKI_API_KEY=your_tiki_key
POS_API_KEY=your_pos_indonesia_key

# WhatsApp API (optional)
WHATSAPP_API_KEY=your_whatsapp_api_key
WHATSAPP_PHONE_NUMBER=your_whatsapp_number

# E-Faktur API (optional)
EFAKTUR_API_KEY=your_efaktur_api_key
EFAKTUR_NPWP=your_company_npwp

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Admin Credentials (initial setup)
ADMIN_EMAIL=admin@bungkus.com
ADMIN_PASSWORD=ChangeThisPassword123!