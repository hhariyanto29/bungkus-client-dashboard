{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["nodemon", "server.js"],
      "port": 3001,
      "cwd": "/tmp/bungkus-client-dashboard/backend"
    },
    {
      "name": "admin",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["start"],
      "port": 3000,
      "cwd": "/tmp/bungkus-client-dashboard/admin",
      "env": {
        "PUBLIC_URL": "/"
      }
    },
    {
      "name": "admin-dashboard",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["start"],
      "port": 3000,
      "cwd": "/tmp/bungkus-client-dashboard/admin-dashboard",
      "env": {
        "PUBLIC_URL": "/"
      }
    },
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["start"],
      "port": 3002,
      "cwd": "/tmp/bungkus-client-dashboard/frontend",
      "env": {
        "PUBLIC_URL": "/",
        "PORT": "3002"
      }
    }
  ]
